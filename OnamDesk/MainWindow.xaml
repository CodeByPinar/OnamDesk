<Window x:Class="OnamDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}"
        Height="820"
        Width="1360"
        MinHeight="760"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#E7EDF5">

    <Window.Resources>

        <!-- Sidebar Navigation Button -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,9"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="ActiveBar"
                                        Grid.Column="0"
                                        Width="4"
                                        CornerRadius="4"
                                        Background="Transparent"
                                        Margin="-6,10,12,10"/>

                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#12263D"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1E3A5F"/>
                                <Setter TargetName="ActiveBar" Property="Background" Value="#22C55E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F766E"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#14B8A6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Logout Button -->
        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
            <Setter Property="Background" Value="#2A1218"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7F1D1D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#991B1B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header Pill -->
        <Style x:Key="HeaderPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

    </Window.Resources>

    <Grid Background="#E7EDF5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="304"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Premium Sidebar -->
        <Border Grid.Column="0"
                Margin="18"
                CornerRadius="30"
                Background="#07111F"
                BorderBrush="#162235"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand Section -->
                <StackPanel Grid.Row="0"
                            Margin="22,24,22,16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="54"
                                Height="54"
                                CornerRadius="18"
                                Background="#0F766E">

                            <TextBlock Text="OD"
                                       Foreground="White"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">

                            <TextBlock Text="OnamDesk"
                                       Foreground="White"
                                       FontSize="27"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Clinical Consent OS"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#0B2B26"
                            BorderBrush="#145B4F"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="13"
                            Margin="0,20,0,0">

                        <StackPanel>
                            <TextBlock Text="🔐 Offline Secure Mode"
                                       Foreground="#A7F3D0"
                                       FontWeight="Bold"
                                       FontSize="13"/>

                            <TextBlock Text="PDF, imza, arşiv ve audit log verileri yerel cihazda saklanır."
                                       Foreground="#6EE7B7"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       LineHeight="17"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1"
                              Margin="18,2,18,8"
                              VerticalScrollBarVisibility="Auto">

                    <StackPanel>
                        <TextBlock Text="ANA MENÜ"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#50657E"
                                   Margin="6,0,0,12"/>

                        <Button Content="🏠  Ana Sayfa"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowDashboardViewCommand}"/>

                        <Button Content="👤  Hasta Yönetimi"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowPatientViewCommand}"/>

                        <Button Content="📝  Onam Formu"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowConsentViewCommand}"/>

                        <Button Content="📁  Arşiv"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowArchiveViewCommand}"/>

                        <Button Content="📋  Şablonlar"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowTemplateViewCommand}"/>

                        <TextBlock Text="SİSTEM"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#50657E"
                                   Margin="6,16,0,12"/>

                        <Button Content="🛡️  Audit Log"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowAuditLogViewCommand}"/>

                        <Button Content="⚙️  Ayarlar"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ShowSettingsViewCommand}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- User / Clinic Card -->
                <StackPanel Grid.Row="2"
                            Margin="18,8,18,22">

                    <Border Background="#0B1625"
                            CornerRadius="22"
                            Padding="16"
                            BorderBrush="#1E2F46"
                            BorderThickness="1">

                        <StackPanel>
                            <DockPanel>
                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="15"
                                        Background="#123F39"
                                        DockPanel.Dock="Left"
                                        Margin="0,0,12,0">

                                    <TextBlock Text="●"
                                               Foreground="#34D399"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel>
                                    <TextBlock Text="Aktif Kullanıcı"
                                               Foreground="#64748B"
                                               FontSize="11"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding CurrentUserName}"
                                               Foreground="White"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <Separator Background="#1E2F46"
                                       Margin="0,15,0,15"/>

                            <TextBlock Text="Aktif Klinik"
                                       Foreground="#64748B"
                                       FontSize="11"
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding ClinicName}"
                                       Foreground="#CBD5E1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>

                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,14,0,0">

                                <TextBlock Text="MVP v1.0 • Backup Enabled"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Button Content="🚪  Çıkış Yap"
                            Style="{StaticResource LogoutButtonStyle}"
                            Command="{Binding LogoutCommand}"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Shell -->
        <Grid Grid.Column="1"
              Margin="0,18,18,18">

            <Grid.RowDefinitions>
                <RowDefinition Height="92"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="28"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    Padding="26,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding ApplicationTitle}"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <TextBlock Text="Hasta aydınlatma, dijital imza, PDF arşivleme, audit log ve güvenli yedekleme paneli"
                                   FontSize="13"
                                   Foreground="#64748B"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Border Style="{StaticResource HeaderPillStyle}"
                                Background="#ECFDF5">

                            <TextBlock Text="● Sistem Aktif"
                                       Foreground="#047857"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </Border>

                        <Border Style="{StaticResource HeaderPillStyle}"
                                Background="#EFF6FF">

                            <TextBlock Text="🔐 Güvenli Oturum"
                                       Foreground="#1D4ED8"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </Border>

                        <Border Style="{StaticResource HeaderPillStyle}"
                                Background="#FFF7ED"
                                Margin="0">

                            <TextBlock Text="💾 Otomatik Yedek"
                                       Foreground="#C2410C"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Container -->
            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Background="#F8FAFC"
                    CornerRadius="30"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Inner Page Header Strip -->
                    <Border Grid.Row="0"
                            Background="#FFFFFF"
                            CornerRadius="30,30,0,0"
                            BorderBrush="#E2E8F0"
                            BorderThickness="0,0,0,1"
                            Padding="22,14">

                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="Operasyon Paneli"
                                           Foreground="#0F172A"
                                           FontSize="16"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Modüller arasında geçiş yaparak onam süreçlerini yönetin."
                                           Foreground="#64748B"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <Border DockPanel.Dock="Right"
                                    Background="#F1F5F9"
                                    CornerRadius="16"
                                    Padding="12,7"
                                    VerticalAlignment="Center">

                                <TextBlock Text="{Binding ClinicName}"
                                           Foreground="#334155"
                                           FontSize="12"
                                           FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                    </Border>

                    <!-- Dynamic Page -->
                    <ContentControl Grid.Row="1"
                                    Content="{Binding CurrentView}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>