<UserControl x:Class="OnamDesk.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1050">

    <Grid Background="#F4F7FA" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Audit Log"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1E293B"/>

            <TextBlock Text="Kritik sistem işlemlerini, kullanıcı hareketlerini ve onam kayıt geçmişini görüntüleyin."
                       FontSize="14"
                       Foreground="#64748B"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- İçerik -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Log Listesi -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    Padding="16"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBox Width="420"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Action, kullanıcı, hasta veya detay içinde ara"/>

                        <Button Content="Yenile"
                                Width="90"
                                Height="36"
                                Margin="10,0,0,0"
                                Command="{Binding LoadAuditLogsCommand}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding AuditLogs}"
                              SelectedItem="{Binding SelectedAuditLog, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="38">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="55"/>

                            <DataGridTextColumn Header="Action"
                                                Binding="{Binding Action}"
                                                Width="160"/>

                            <DataGridTextColumn Header="Kullanıcı"
                                                Binding="{Binding UserName}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Hasta"
                                                Binding="{Binding ConsentForm.Patient.FullName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Tarih"
                                                Binding="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}"
                                                Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Sağ: Detay Paneli -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="14"
                    Padding="20"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Log Detayı"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Action"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedAuditLog.Action}"
                                   Foreground="#0F172A"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,4,0,14"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Kullanıcı"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedAuditLog.UserName}"
                                   Foreground="#0F172A"
                                   FontSize="15"
                                   Margin="0,4,0,14"/>

                        <TextBlock Text="Zaman"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedAuditLog.Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}"
                                   Foreground="#0F172A"
                                   FontSize="15"
                                   Margin="0,4,0,14"/>

                        <TextBlock Text="İlgili Onam ID"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedAuditLog.ConsentId}"
                                   Foreground="#0F172A"
                                   FontSize="15"
                                   Margin="0,4,0,14"/>

                        <TextBlock Text="Hasta"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SelectedAuditLog.ConsentForm.Patient.FullName}"
                                   Foreground="#0F172A"
                                   FontSize="15"
                                   Margin="0,4,0,14"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="JSON Detay"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>

                        <Border Background="#0F172A"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,4,0,0">

                            <TextBlock Text="{Binding SelectedAuditLog.Details}"
                                       Foreground="#E2E8F0"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Durum Mesajı -->
        <Border Grid.Row="2"
                Background="#E0F2FE"
                CornerRadius="10"
                Padding="12"
                Margin="0,16,0,0">

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#0369A1"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</UserControl>