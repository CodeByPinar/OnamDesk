<UserControl x:Class="OnamDesk.Views.TemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1050">

    <Grid Background="#F4F7FA" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Şablon Yönetimi"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1E293B"/>

            <TextBlock Text="Onam formu şablonlarını, açıklama metinlerini ve risk listelerini yönetin."
                       FontSize="14"
                       Foreground="#64748B"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- İçerik -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1.45*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Şablon Listesi -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    Padding="16"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBox Width="380"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Şablon adı, kategori veya risk metni ile ara"/>

                        <Button Content="Yenile"
                                Width="90"
                                Height="36"
                                Margin="10,0,0,0"
                                Command="{Binding LoadTemplatesCommand}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Templates}"
                              SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="36">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="55"/>

                            <DataGridTextColumn Header="Şablon"
                                                Binding="{Binding Name}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Kategori"
                                                Binding="{Binding Category}"
                                                Width="140"/>

                            <DataGridCheckBoxColumn Header="Aktif"
                                                    Binding="{Binding IsActive}"
                                                    Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Sağ: Form -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="14"
                    Padding="20"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Şablon Bilgileri"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#1E293B"
                               Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">

                        <StackPanel>
                            <TextBlock Text="Şablon Adı"
                                       Foreground="#475569"
                                       Margin="0,0,0,4"/>

                            <TextBox Height="36"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Kategori"
                                       Foreground="#475569"
                                       Margin="0,14,0,4"/>

                            <TextBox Height="36"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Açıklama / İçerik"
                                       Foreground="#475569"
                                       Margin="0,14,0,4"/>

                            <TextBox Height="120"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="10"
                                     Text="{Binding ContentJson, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Risk ve Komplikasyonlar"
                                       Foreground="#475569"
                                       Margin="0,14,0,4"/>

                            <TextBox Height="120"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="10"
                                     Text="{Binding Risks, UpdateSourceTrigger=PropertyChanged}"/>

                            <CheckBox Content="Şablon aktif"
                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      Margin="0,16,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Orientation="Vertical"
                                Margin="0,18,0,0">

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Ekle"
                                    Width="90"
                                    Height="38"
                                    Command="{Binding AddTemplateCommand}"/>

                            <Button Content="Güncelle"
                                    Width="90"
                                    Height="38"
                                    Margin="10,0,0,0"
                                    Command="{Binding UpdateTemplateCommand}"/>

                            <Button Content="Sil"
                                    Width="90"
                                    Height="38"
                                    Margin="10,0,0,0"
                                    Command="{Binding DeleteTemplateCommand}"/>
                        </StackPanel>

                        <Button Content="Formu Temizle"
                                Height="38"
                                Margin="0,12,0,0"
                                Command="{Binding ClearFormCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Durum Mesajı -->
        <Border Grid.Row="2"
                Background="#ECFDF5"
                CornerRadius="10"
                Padding="12"
                Margin="0,16,0,0">

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#047857"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</UserControl>
