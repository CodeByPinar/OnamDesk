<Window x:Class="OnamDesk.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OnamDesk Giriş"
        Height="560"
        Width="900"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#E5EAF0">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0F766E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D9488"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#115E59"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#E5EAF0">
        <Border Margin="32"
                CornerRadius="26"
                Background="White"
                BorderBrush="#DDE5EF"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sol Marka Paneli -->
                <Border Grid.Column="0"
                        CornerRadius="26,0,0,26"
                        Background="#0F172A">

                    <Grid Margin="32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Border Width="58"
                                    Height="58"
                                    CornerRadius="18"
                                    Background="#14B8A6"
                                    HorizontalAlignment="Left">

                                <TextBlock Text="OD"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="OnamDesk"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,22,0,0"/>

                            <TextBlock Text="Hasta Aydınlatma ve Onay Otomasyon Sistemi"
                                       FontSize="14"
                                       Foreground="#CBD5E1"
                                       TextWrapping="Wrap"
                                       LineHeight="22"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center">

                            <Border Background="#111827"
                                    CornerRadius="18"
                                    Padding="18"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    Margin="0,0,0,14">

                                <StackPanel>
                                    <TextBlock Text="● Offline güvenli çalışma"
                                               Foreground="#A7F3D0"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="Veriler klinik bilgisayarında saklanır."
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#111827"
                                    CornerRadius="18"
                                    Padding="18"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    Margin="0,0,0,14">

                                <StackPanel>
                                    <TextBlock Text="● İmza hash doğrulama"
                                               Foreground="#BFDBFE"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="Onam kayıt bütünlüğü kontrol edilir."
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#111827"
                                    CornerRadius="18"
                                    Padding="18"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1">

                                <StackPanel>
                                    <TextBlock Text="● Audit log desteği"
                                               Foreground="#FDE68A"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="Kritik işlemler kayıt altına alınır."
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="MVP v1.0 · .NET 8 WPF"
                                   Foreground="#64748B"
                                   FontSize="12"/>
                    </Grid>
                </Border>

                <!-- Sağ Login Paneli -->
                <Grid Grid.Column="1"
                      Background="#F8FAFC">

                    <Border Width="390"
                            Background="White"
                            CornerRadius="24"
                            Padding="32"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <StackPanel>
                            <TextBlock Text="Güvenli Giriş"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="OnamDesk uygulamasına devam etmek için şifrenizi girin."
                                       FontSize="14"
                                       Foreground="#64748B"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,28"/>

                            <TextBlock Text="Uygulama Şifresi"
                                       Foreground="#334155"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <Border Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="12">

                                <PasswordBox x:Name="PasswordInput"
                                             Height="44"
                                             FontSize="16"
                                             Padding="12,0"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="PasswordInput_PasswordChanged"/>
                            </Border>

                            <Button Content="Giriş Yap"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,18,0,0"
                                    Command="{Binding LoginCommand}"/>

                            <Border Background="#F1F5F9"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,18,0,0">

                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="#334155"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </Border>

                            <Border Background="#ECFDF5"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,18,0,0">

                                <TextBlock Text="İlk giriş için varsayılan şifre: onam1234"
                                           Foreground="#047857"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>